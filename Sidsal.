<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sidsal | Elegance in Every Dip</title>
    <style>
        /* Color Palette */
        :root {
            --baby-pink: #fce4ec;
            --dark-chocolate: #3e2723;
            --soft-white: #fafafa;
            --gold-accent: #d4af37;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background-color: var(--soft-white);
            color: var(--dark-chocolate);
            line-height: 1.6;
        }

        /* Header */
        header {
            background-color: var(--baby-pink);
            padding: 40px 20px;
            text-align: center;
            border-bottom: 5px solid var(--dark-chocolate);
        }

        header h1 {
            font-size: 3rem;
            margin: 0;
            letter-spacing: 2px;
            text-transform: lowercase; /* Matching your logo style */
        }

        header p {
            font-style: italic;
            margin-top: 10px;
        }

        /* Hero Section */
        .hero {
            padding: 60px 20px;
            text-align: center;
            background: linear-gradient(rgba(255,255,255,0.8), rgba(255,255,255,0.8)), url('https://images.unsplash.com/photo-1590486803833-ffc6f08d6fb5?auto=format&fit=crop&w=800&q=80');
            background-size: cover;
            background-position: center;
        }

        /* Menu Section */
        .container {
            max-width: 900px;
            margin: auto;
            padding: 40px 20px;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .menu-item {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            text-align: center;
            border: 1px solid var(--baby-pink);
            transition: transform 0.3s;
        }

        .menu-item:hover {
            transform: translateY(-5px);
        }

        .price {
            font-weight: bold;
            color: var(--gold-accent);
            font-size: 1.2rem;
        }

        /* CTA Button */
        .btn {
            display: inline-block;
            background-color: var(--dark-chocolate);
            color: white;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 25px;
            margin-top: 20px;
            font-weight: bold;
        }

        footer {
            text-align: center;
            padding: 40px;
            background-color: var(--dark-chocolate);
            color: var(--baby-pink);
        }
    </style>
</head>
<body>

<header>
    <h1>sidsal</h1>
    <p>Elegance in Every Dip</p>
</header>

<section class="hero">
    <h2>Fresh Strawberries. Premium Chocolate.</h2>
    <p>Handcrafted sweets for your modern lifestyle.</p>
    <a href="#menu" class="btn">View the Menu</a>
</section>

<div class="container" id="menu">
    <h2 style="text-align: center; margin-bottom: 40px;">On The Counter</h2>
    <div class="menu-grid">
        <div class="menu-item">
            <h3>Solo Skewer</h3>
            <p>2 Jumbo Berries dipped in silk chocolate.</p>
            <p class="price">₹149</p>
        </div>
        <div class="menu-item">
            <h3>Sidsal Cup</h3>
            <p>4 Berries with a waterfall of warm dip.</p>
            <p class="price">₹249</p>
        </div>
        <div class="menu-item">
            <h3>The Share Box</h3>
            <p>6 Decorated premium berries.</p>
            <p class="price">₹399</p>
        </div>
    </div>
</div>

<footer>
    <p>&copy; 2026 Sidsal Confections</p>
    <p>Follow us for stall locations: @sidsal_confections</p>
</footer>

</body>
</html>
